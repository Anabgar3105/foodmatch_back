spring.application.name=FoodMatch


spring.datasource.url=jdbc:mysql://localhost:3306/foodmatch_db
spring.datasource.username=PON_AQUI_TU_USUARIO
spring.datasource.password=PON_AQUI_TU_CONTRASEÑA

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

spring.sql.init.mode=never
spring.sql.init.continue-on-error=true

server.port=8080

logging.level.org.springframework.security=INFO

# Genera una cadena aleatoria larga (mínimo 32 caracteres) codificada en Base64 para usar como secreto JWT.
jwt.secret=PON_AQUI_TU_SECRETO
jwt.expiration=86400000

springdoc.swagger-ui.path=/swagger-ui.html
springdoc.api-docs.path=/v3/api-docs